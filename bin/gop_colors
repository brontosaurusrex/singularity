#!/usr/bin/env bash

# GOP8

input="$1"

RED="\033[31m"
GREEN="\033[32m"
BLUE="\033[34m"
RESET="\033[0m"

ffprobe -v error \
  -select_streams v:0 \
  -show_frames \
  -show_entries frame=pict_type,pkt_size \
  -of csv=p=0 "$1" |
awk -F',' -v R="\033[31m" -v G="\033[32m" -v B="\033[34m" -v X="\033[0m" '
{
    type=""
    size=""

    for (i=1; i<=NF; i++) {
        if ($i ~ /^[IPB]$/) type=$i
        if ($i ~ /^[0-9]+$/) size=$i
    }

    if (!type && size) type="I"

    if (type && size) {
        color = (type=="I") ? R : (type=="P") ? G : B
        printf "%6d  %s%s%s  %8d bytes\n", NR, color, type, X, size
    }
}
'
